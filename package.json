{
  "name": "ask-pebble",
  "author": "Katsuya Ohta",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "Ask Pebble",
    "uuid": "0050cb35-633f-4301-992e-4a558462f29f",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [
      "configurable",
      "health",
      "location",
      "microphone"
    ],
    "messageKeys": {
      "type": 1,
      "requestId": 2,
      "utterance": 3,
      "status": 4,
      "answer": 5,
      "errorCode": 6,
      "message": 7,
      "hasApiKey": 8,
      "stepsToday": 9,
      "activeMinutesToday": 10,
      "sleepTodayMinutes": 11,
      "restfulSleepTodayMinutes": 12,
      "healthAvailable": 13
    },
    "resources": {
      "media": [
        {
          "type": "raw",
          "name": "CONFIG_PAGE",
          "file": "config.html"
        }
      ]
    }
  }
}
